# Flask
SECRET_KEY=troque-por-uma-chave-segura-de-32-chars
APP_BASE_URL=https://seu-projeto.vercel.app

# Astra DB (DataStax) — deixe em branco para usar modo local (in-memory)
ASTRA_DB_API_ENDPOINT=https://SEU_DB_ID-us-east-2.apps.astra.datastax.com
ASTRA_DB_APPLICATION_TOKEN=seu-token-do-astra
ASTRA_DB_KEYSPACE=default_keyspace
ASTRA_DB_COLLECTION_USERS=taxistas
ASTRA_DB_COLLECTION_RECEIPTS=recibos

# Stripe — obtenha em https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs dos preços criados no Stripe Dashboard
# Produto: "Recibo Táxi Pro" — cobrança mensal
STRIPE_PRO_PRICE_ID=price_...
# Produto: "Recibo Táxi Business" — cobrança mensal
STRIPE_BUSINESS_PRICE_ID=price_...
